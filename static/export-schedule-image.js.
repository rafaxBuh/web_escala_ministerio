/* ── Exportar Escala como Imagem (PNG) ──────────────────────────────────────
 * Gera um card estilizado com a identidade visual do Zelo a partir dos dados
 * já presentes na página (sem chamada ao servidor) e baixa como PNG usando
 * html2canvas. Funciona tanto na tela de Escala (períodos semanais) quanto
 * na tela de Escala de Evento (dias + turnos)
 * ──────────────────────────────────────────────────────────────────────── */

(function () {

  function isDark() {
    return document.documentElement.classList.contains('dark-mode');
  }

  function buildCardShell(title, subtitle) {
    const dark = isDark();
    const bg     = dark ? '#15151A' : '#FFFFFF';
    const text   = dark ? '#F2F2F5' : '#1F1F24';
    const muted  = dark ? '#8B8F99' : '#A6AAB4';
    const border = dark ? '#262630' : '#F0F0F0';

    const card = document.createElement('div');
    card.style.cssText = `
      width: 720px;
      padding: 2rem 2.25rem 2.5rem;
      background: ${bg};
      color: ${text};
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      box-sizing: border-box;
    `;

    card.innerHTML = `
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem;">
        <span style="font-family:'Playfair Display',serif;font-size:1.75rem;font-weight:700;letter-spacing:.04em;color:${text};">ZELO</span>
        <span style="font-size:.75rem;font-weight:600;color:${muted};text-transform:uppercase;letter-spacing:.06em;">Escala Ministerial</span>
      </div>
      <div style="margin-bottom:1.5rem;">
        <div style="font-size:1.375rem;font-weight:800;color:${text};margin-bottom:.25rem;">${title}</div>
        <div style="font-size:.9375rem;color:${muted};">${subtitle}</div>
      </div>
      <div data-zelo-body style="display:flex;flex-direction:column;gap:1.125rem;"></div>
      <div style="margin-top:2rem;padding-top:1rem;border-top:1px solid ${border};font-size:.75rem;color:${muted};text-align:center;">
        Gerado pelo ZELO
      </div>
    `;
    return card;
  }

  function memberRow(name, badgeText) {
    const dark = isDark();
    const primaryLight = dark ? 'rgba(32, 225, 201, 0.15)' : '#e0faf7';
    const primary = '#20E1C9';
    const text = dark ? '#F2F2F5' : '#1F1F24';
    const badge = badgeText
      ? `<span style="font-size:.625rem;font-weight:700;color:${primary};background:${dark ? 'rgba(32,225,201,.2)' : '#fff'};border-radius:6px;padding:.15rem .5rem;margin-left:.5rem;">${badgeText}</span>`
      : '';
    return `
      <div style="display:flex;align-items:center;gap:.5rem;background:${primaryLight};
                  border-radius:10px;padding:.45rem .75rem;border-left:3px solid ${primary};">
        <span style="font-weight:600;font-size:.9375rem;color:${text};">${name}</span>
        ${badge}
      </div>
    `;
  }

  function sectionBlock(label, rowsHtml, dark) {
    const border = dark ? '#262630' : '#F0F0F0';
    const muted  = dark ? '#8B8F99' : '#A6AAB4';
    return `
      <div style="padding-bottom:1rem;${border ? `border-bottom:1px solid ${border};` : ''}">
        <div style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;
                    color:${muted};margin-bottom:.5rem;">${label}</div>
        <div style="display:flex;flex-direction:column;gap:.4rem;">
          ${rowsHtml || `<span style="font-size:.8125rem;color:${muted};">Sem voluntários</span>`}
        </div>
      </div>
    `;
  }

  async function renderAndDownload(card, filename) {
    document.body.appendChild(card);
    card.style.position = 'fixed';
    card.style.left = '-9999px';
    card.style.top = '0';

    try {
      const canvas = await html2canvas(card, {
        scale: 2,
        backgroundColor: isDark() ? '#15151A' : '#FFFFFF',
        useCORS: true,
      });
      const link = document.createElement('a');
      link.download = filename;
      link.href = canvas.toDataURL('image/png');
      link.click();
    } catch (err) {
      console.error('Falha ao gerar imagem da escala:', err);
      alert('Não foi possível gerar a imagem. Tente novamente.');
    } finally {
      document.body.removeChild(card);
    }
  }

  /* ── Escala por período (schedule.html) ──────────────────────────────── */
  // Lê as linhas já renderizadas em .card [Semana N — label] / .member-name
  window.exportPeriodScheduleImage = async function (ministryName, periodLabel) {
    const dark = isDark();
    const card = buildCardShell(ministryName, `Escala de ${periodLabel}`);
    const body = card.querySelector('[data-zelo-body]');

    const weekBlocks = document.querySelectorAll('#schedule-readonly-block > div > div');
    let html = '';
    document.querySelectorAll('[data-week-block]').forEach((block) => {
      const label = block.querySelector('[data-week-label]')?.textContent?.trim() || '';
      const names = Array.from(block.querySelectorAll('[data-week-member]')).map((el) => ({
        name: el.dataset.weekMember,
        badge: el.dataset.weekBadge || '',
      }));
      const rows = names.map((n) => memberRow(n.name, n.badge)).join('');
      html += sectionBlock(label, rows, dark);
    });

    body.innerHTML = html || `<span style="font-size:.875rem;color:#A6AAB4;">Nenhuma escala gerada ainda.</span>`;
    await renderAndDownload(card, `escala-${ministryName.toLowerCase().replace(/\s+/g, '-')}.png`);
  };

  /* ── Escala por evento (event_schedule.html) ─────────────────────────── */
  window.exportEventScheduleImage = async function (eventTitle, eventSubtitle) {
    const dark = isDark();
    const card = buildCardShell(eventTitle, eventSubtitle);
    const body = card.querySelector('[data-zelo-body]');

    let html = '';
    document.querySelectorAll('[data-day-block]').forEach((dayBlock) => {
      const dayLabel = dayBlock.querySelector('[data-day-label]')?.textContent?.trim() || '';
      let rows = '';
      dayBlock.querySelectorAll('[data-period-block]').forEach((periodBlock) => {
        const periodLabel = periodBlock.dataset.periodLabel || '';
        const members = Array.from(periodBlock.querySelectorAll('[data-slot-member]'))
          .map((el) => el.textContent.trim());
        if (members.length) {
          rows += `<div style="font-size:.8125rem;font-weight:700;color:#20E1C9;margin-top:.5rem;">${periodLabel}</div>`;
          rows += members.map((m) => memberRow(m)).join('');
        }
      });
      if (rows) html += sectionBlock(dayLabel, rows, dark);
    });

    body.innerHTML = html || `<span style="font-size:.875rem;color:#A6AAB4;">Nenhum voluntário escalado ainda.</span>`;
    await renderAndDownload(card, `escala-evento-${eventTitle.toLowerCase().replace(/\s+/g, '-')}.png`);
  };

})();
